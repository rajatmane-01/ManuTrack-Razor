<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ManuTrack</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <style>
        .navbar-brand { font-weight: bold; font-size: 1.4rem; }
        .badge-admin { background-color: #6f42c1; }
        .badge-planner { background-color: #0d6efd; }
        .badge-operator { background-color: #198754; }
        .badge-inspector { background-color: #ffc107; color: #000; }
        .badge-inventory { background-color: #fd7e14; }
        .badge-compliance { background-color: #dc3545; }
        .sidebar { min-height: calc(100vh - 56px); background: #f8f9fa; }
        .nav-link.active { background-color: #e9ecef; border-radius: 6px; }
    </style>
</head>
<body>

@if (Context.Session.GetString("token") != null)
{
    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-primary px-4">
        <a class="navbar-brand" href="/Dashboard/Index">ManuTrack</a>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white small">
                @Context.Session.GetString("name")
            </span>
            <span class="badge bg-light text-dark">
                @Context.Session.GetString("role")
            </span>
            <a href="/Auth/Logout" class="btn btn-outline-light btn-sm">
                Logout
            </a>
        </div>
    </nav>

    <!-- Sidebar + Content -->
    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-md-2 sidebar py-3 px-3">
                <ul class="nav flex-column gap-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="/Dashboard/Index">
                            Dashboard
                        </a>
                    </li>

                    @if (Context.Session.GetString("role") == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Users/Index">
                                Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Auth/AuditLogs">
                                Audit Logs
                            </a>
                        </li>
                    }

                        @if (Context.Session.GetString("role") == "ComplianceOfficer")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Auth/AuditLogs">
                                    Audit Logs
                                </a>
                            </li>
                        }

                    @if (Context.Session.GetString("role") == "Admin" ||
                         Context.Session.GetString("role") == "Planner")
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Products/Index">
                                Products & BOM
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link text-dark" href="/WorkOrders/Index">
                            Work Orders
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 py-4 px-4">
                @RenderBody()
            </div>

        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
</script>
</body>
</html>