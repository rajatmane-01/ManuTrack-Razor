@page
@model ManuTrackAPI.Pages.Auth.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>ManuTrack — Register Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>
<body class="bg-light">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <div class="text-center mb-4">
                        <h2 class="text-primary fw-bold">ManuTrack</h2>
                        <p class="text-muted small">Register System Admin</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger small">
                            @Model.ErrorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="alert alert-success small">
                            @Model.SuccessMessage
                            <a href="/Auth/Login">Click here to login</a>
                        </div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Name</label>
                            <input asp-for="Name" class="form-control"
                                   placeholder="Full name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Email</label>
                            <input asp-for="Email" type="email"
                                   class="form-control"
                                   placeholder="Email address" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Phone</label>
                            <input asp-for="Phone" class="form-control"
                                   placeholder="Phone number" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Password</label>
                            <input asp-for="Password" type="password"
                                   class="form-control"
                                   placeholder="Password" />
                        </div>
                        <button type="submit"
                                class="btn btn-primary w-100 fw-bold">
                            Register as Admin
                        </button>
                    </form>

                    <p class="text-center mt-3 small">
                        Already have an account?
                        <a href="/Auth/Login">Login here</a>
                    </p>

                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>