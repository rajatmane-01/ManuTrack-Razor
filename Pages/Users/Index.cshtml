@page
@model ManuTrackAPI.Pages.Users.IndexModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Users Management</h4>
    <button class="btn btn-primary btn-sm"
            onclick="document.getElementById('createForm').classList.toggle('d-none')">
        + Add User
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Create User Form -->
<div id="createForm" class="card shadow-sm mb-4 d-none">
    <div class="card-body">
        <h5 class="fw-bold mb-3">Create New User</h5>
        <form method="post" asp-page-handler="Create">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Name</label>
                    <input name="Name" class="form-control" placeholder="Full name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Email</label>
                    <input name="Email" type="email" class="form-control"
                           placeholder="Email address" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Phone</label>
                    <input name="Phone" class="form-control"
                           placeholder="Phone number" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Role</label>
                    <select name="Role" class="form-select">
                        <option value="Planner">Planner</option>
                        <option value="Operator">Operator</option>
                        <option value="Inspector">Inspector</option>
                        <option value="InventoryManager">InventoryManager</option>
                        <option value="ComplianceOfficer">ComplianceOfficer</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Password</label>
                    <input name="Password" type="password" class="form-control"
                           placeholder="Password" />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    Create User
                </button>
                <button type="button" class="btn btn-secondary btn-sm"
                        onclick="document.getElementById('createForm').classList.add('d-none')">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Users Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td class="text-muted small">@user.UserID</td>
                        <td class="fw-bold">@user.Name</td>
                        <td class="text-muted small">@user.Email</td>
                        <td>
                            <span class="badge bg-primary">@user.Role</span>
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td class="text-muted small">
                            @user.CreatedAt.ToString("dd/MM/yyyy")
                        </td>
                        <td>
    @if (user.Role != "Admin")
    {
        @if (user.IsActive)
        {
            <!-- Deactivate button for active users -->
            <form method="post"
                  asp-page-handler="Deactivate"
                  style="display:inline">
                <input type="hidden"
                       name="userId"
                       value="@user.UserID" />
                <button type="submit"
                        class="btn btn-warning btn-sm"
                        onclick="return confirm('Deactivate this user?')">
                    Deactivate
                </button>
            </form>
        }
        else
        {
            <!-- Activate button for inactive users -->
            <form method="post"
                  asp-page-handler="Activate"
                  style="display:inline">
                <input type="hidden"
                       name="userId"
                       value="@user.UserID" />
                <button type="submit"
                        class="btn btn-success btn-sm"
                        onclick="return confirm('Activate this user?')">
                    Activate
                </button>
            </form>
        }
    }
</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>